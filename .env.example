# ─── SORO Environment Variables ───

# App
APP_NAME=SORO API
APP_VERSION=0.1.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/soro
DATABASE_NAME=soro

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Redis (Upstash — optional)
REDIS_URL=

# Groq API (Free tier: 14,400 req/day)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback if Groq is unavailable — optional)
GEMINI_API_KEY=

# Sendhiiv (Transactional email — free tier)
# Sign up at: https://sendhiiv.com
SENDHIIV_API_KEY=

# Crisis helpline (MANI)
CRISIS_NUMBER=08111909909
CRISIS_ORGANIZATION=MANI Helpline
