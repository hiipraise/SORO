[TEMPLATE]
# ─── SORO Backend Environment Configuration ───
# Copy this file to .env and fill in your values.
# Required variables are marked [REQUIRED]; everything else is optional.

# ─── App ───
APP_NAME=SORO API
APP_VERSION=0.1.0
DEBUG=false                              # Set to true for local development only
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://soro.pxxl.click,https://soro.axiomcv.site   # Comma-separated allowed origins

# ─── MongoDB ───
# [REQUIRED] MongoDB connection string
# Local: mongodb://localhost:27017/soro
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/soro?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/soro
DATABASE_NAME=soro

# ─── JWT ───
# [REQUIRED] Generate a strong random secret:
#   openssl rand -hex 32
# Do NOT reuse the default value in production.
JWT_SECRET=change-me-in-production-soro-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440                   # Token lifetime in minutes (1440 = 24h)

# ─── Redis (Upstash) ───
# Optional. Used for rate-limit storage (avoid in-memory resets on free-tier restarts).
REDIS_URL=                                # e.g. redis://<user>:<pass>@<host>:<port>

# ─── Groq AI ───
# [REQUIRED for AI reflections] Get your free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MAX_TOKENS=200
GROQ_TEMPERATURE=0.7

# ─── Gemini (fallback) ───
# Optional. Used as fallback when Groq is unavailable.
GEMINI_API_KEY=

# ─── Sendhiiv ───
# Optional transactional email service. Get your API key at https://sendhiiv.com
SENDHIIV_API_KEY=
SENDHIIV_URL=https://api.sendhiiv.com/api/v1/messages

# ─── Scheduler ───
SCHEDULER_ENABLED=false                   # Set to true to enable weekly digest emails
DIGEST_DAY=Sunday
DIGEST_HOUR=8                             # 8 AM WAT
DIGEST_MINUTE=0

# ─── Crisis Helpline ───
CRISIS_NUMBER=08111909909                 # MANI Helpline
CRISIS_ORGANIZATION=MANI Helpline
