# ─── SORO Backend Configuration ───
# Copy this file to .env and fill in your values

# App
APP_NAME=SORO API
APP_VERSION=0.1.0
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# MongoDB — Get a free M0 cluster at https://mongodb.com
MONGO_URI=mongodb://localhost:27017/soro

# JWT — Change this to a long random string in production
JWT_SECRET=change-me-in-production-soro-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Upstash Redis (free tier) — https://upstash.com
# REDIS_URL=redis://default:<password>@<endpoint>.upstash.io:6379

# Groq AI (14,400 req/day free) — https://console.groq.com
# GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini AI (fallback) — https://aistudio.google.com
# GEMINI_API_KEY=your_api_key_here

# Sendhiiv Email — https://sendhiiv.com
# SENDHIIV_API_KEY=your_api_key_here

# Crisis Helpline
CRISIS_NUMBER=08111909909
CRISIS_ORGANIZATION=MANI Helpline
