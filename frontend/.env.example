[TEMPLATE]
# ─── SORO Frontend Configuration ───
# Copy this file to .env and fill in your values
#
# Vite loads environment-specific files automatically:
#   .env.development  — when running `vite dev`
#   .env.production   — when running `vite build` / `vite preview`
#   .env              — always loaded (lowest priority)

# API Base URL
# In development, the Vite proxy handles /api -> localhost:8000
# In production, set this to your backend URL. If omitted in production,
# the app falls back to https://soro-qk1e.onrender.com.
VITE_API_URL=https://soro-qk1e.onrender.com

# ─── Ads Configuration ───
# VITE_ADS_ENABLED: Set to "true" to show ad slots
# VITE_ADS_MODE:    "placeholder" — shows styled placeholder (for dev)
#                   "live"        — shows empty slot ready for AdSense (for prod)
# VITE_ADS_ENABLED=false
# VITE_ADS_MODE=placeholder
